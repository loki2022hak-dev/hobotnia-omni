datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String          @id @default(uuid())
  nickname       String          @unique
  avatarUrl      String?
  walletBalance  Float           @default(12450.00)
  isVip          Boolean         @default(false)
  vipPlan        String?
  vipExpiresAt   DateTime?
  
  speed          Int             @default(40)
  grid          Int             @default(30)
  nitro          Int             @default(30)
  
  purchasedItems String[]        @default([])
  usedPromos     String[]        @default([])
  createdAt      DateTime        @default(now())
  
  rooms          Room[]          @relation("RoomCreator")
  transactions   Transaction[]   @relation("UserTransactions")
  invoices       Invoice[]       @relation("UserInvoices")
  messages       Message[]       
  sentDMs        DirectMessage[] @relation("DMSender")
  receivedDMs    DirectMessage[] @relation("DMReceiver")
  
  // Нові зв'язки для Хобот-Грама
  posts          Post[]
  stories        Story[]
}

model Message {
  id        String   @id @default(uuid())
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model DirectMessage {
  id         String   @id @default(uuid())
  text       String
  senderId   String
  sender     User     @relation("DMSender", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("DMReceiver", fields: [receiverId], references: [id])
  createdAt  DateTime @default(now())
}

model Post {
  id        String   @id @default(uuid())
  imageUrl  String
  caption   String
  likes     Int      @default(0)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Story {
  id        String   @id @default(uuid())
  mediaUrl  String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime // Для логіки 24 годин
  createdAt DateTime @default(now())
}

model Transaction {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation("UserTransactions", fields: [userId], references: [id])
  amount        Float
  type          String
  status        String
  txHash        String   @unique
  createdAt     DateTime @default(now())
}

model Room {
  id           String   @id @default(uuid())
  name         String
  bet          Float
  playersCount Int      @default(1)
  playersMax   Int      @default(4)
  status       String   @default("Очікування")
  trackType    String
  creatorId    String
  creator      User     @relation("RoomCreator", fields: [creatorId], references: [id])
  createdAt    DateTime @default(now())
}

model Invoice {
  id        String   @id @default(uuid())
  amount    Float
  status    String
  userId    String
  user      User     @relation("UserInvoices", fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
